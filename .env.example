# Copy to ".env" locally. Commit only this template — never real API keys or prod secrets.
#
# ── LLM Provider ────────────────────────────────────────────────────────────
# Pick one. ADK uses GOOGLE_API_KEY by default; for others, wire in litellm.
GOOGLE_API_KEY=your-google-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./helix_srop.db
# Postgres (for Postgres-compatible schema):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/helix_srop

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
# LANCEDB_PATH=./lancedb
# PINECONE_API_KEY=...
# PINECONE_INDEX=helix-docs

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-prod     # optional; loaded by Settings, unused by current routes (keep for future auth)

# ── Model Selection ───────────────────────────────────────────────────────────
# Which model the ADK agents use. Gemini Flash is fast + cheap for dev.
ADK_MODEL=gemini-2.0-flash       # or: gemini-1.5-pro, gpt-4o, claude-3-5-sonnet

# ── Agent Timeouts ────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=30
TOOL_TIMEOUT_SECONDS=10

# ── Extensions (E1, E4, E5) ─────────────────────────────────────────────────────
IDEMPOTENCY_ENABLED=true
RERANK_ENABLED=true
RERANK_OVERSAMPLE=3
GUARDRAILS_ENABLED=true

# Optional: base URL for eval/run_eval.py when not passing --base-url
# EVAL_BASE_URL=http://127.0.0.1:8000
